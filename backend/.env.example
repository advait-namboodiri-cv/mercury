# copy to .env and fill in your own values

# absolute path to your Obsidian vault root (the folder that holds your notes)
VAULT_PATH=/Users/you/Obsidian/MyVault

# mlx model id (Hugging Face repo, mlx-community quant of qwen3)
MLX_MODEL=mlx-community/Qwen3-14B-4bit

# port the mercury backend runs on
PORT=8000
